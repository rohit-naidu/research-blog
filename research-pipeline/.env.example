# Copy this file to .env (without .example) and fill in your real keys.
# The real .env is gitignored so secrets never get committed.
#
# How to copy:
#   cp .env.example .env
# Then open .env in any editor and paste your keys.

# OpenAI API key. Required.
# Get one at: https://platform.openai.com/api-keys
# Your account must be on Tier 3 or higher to use Deep Research /
# web_search_preview + reasoning models. If it's not, the pipeline will
# fall back to GPT-5 with web_search_preview in an agentic loop (less deep
# but cheaper). The preflight check tells you which path you're on.
OPENAI_API_KEY=sk-...

# xAI Grok API key. Required.
# Get one at: https://console.x.ai
# We use Grok 4 with live search (DeepSearch equivalent) for the community
# signal layer - X posts, Reddit, biohacker forums.
XAI_API_KEY=xai-...

# Optional: Anthropic Claude key. Currently unused in Tier 2 (we run on
# OpenAI + Grok only per the plan). Leave blank unless you want to enable
# the optional Claude polish pass later.
ANTHROPIC_API_KEY=

# Optional override: where the published Jekyll site lives. Defaults to the
# parent directory (../). Only change this if you moved the pipeline.
JEKYLL_ROOT=..
